# Copy this file to ".env" and fill in real values.
# The real .env is gitignored and must NEVER be committed.

# --- Groq (powers the CHAT model — FREE, no credit card) ---
# Sign up and create a key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-key-here

# --- Qdrant Cloud (the vector database) ---
# Create a free cluster at https://cloud.qdrant.io
# URL looks like: https://xxxxxxxx-xxxx.region.aws.cloud.qdrant.io:6333
QDRANT_URL=https://your-cluster-url.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key-here

# --- Optional: override defaults if you want (safe to leave as-is) ---
# Name of the Qdrant collection holding the document vectors.
QDRANT_COLLECTION=iphone_user_guide
# Embedding model (runs locally via FastEmbed; no key needed). 384 dims.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Chat model served by Groq.
CHAT_MODEL=llama-3.3-70b-versatile
# Number of chunks retrieved per question.
TOP_K=4
# Chunking parameters (only relevant when re-running ingestion).
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
# Port the app serves on (used for docker -p mapping).
APP_PORT=8501
# Where FastEmbed caches its model inside Docker (set by the Dockerfile).
# Leave unset on your local machine.
# FASTEMBED_CACHE_DIR=/app/models
